#include <stdio.h>
#include "main.h"

/**
 * *_strncpy - Entry point
 *
 * Concatenate
 *
 * @dest : pointer to destination (first) string
 * @src : pointer to second string
 * @n : n = max bytes
 * Return: pointer to string start
 */
char *_strncpy(char *dest, char *src, int n)
{
	int i = 0, str1_lenght = 0;

	while ((dest[i] != '\0') && (i < n))
	{
		dest[i] = src[i];
		i++;
	}
	return (dest);
}
