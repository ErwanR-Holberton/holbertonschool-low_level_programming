#include <stdio.h>
#include "main.h"

/**
 * *_strcmp - Entry point
 *
 * Concatenate
 *
 * @a : pointer to first string
 * @n : n of items in array
 *
 *
 */
void reverse_array(int *a, int n)
{
	int i = 0, tempo = 0;

	for (i = 0; i <= n / 2 ; i++)
	{
		tempo = a[i];
		a[i] = a[n - i - 1];
		a[n - i - 1] = tempo;
	}
}
